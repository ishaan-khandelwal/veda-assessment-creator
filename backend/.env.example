# Port the Express server listens on
PORT=5000

# MongoDB connection URI (falls back to local memory if not specified)
MONGODB_URI=mongodb://localhost:27017/veda-assessment

# Redis server options (falls back to local in-process queue if not specified)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Google Gemini API key (optional - if omitted, fallback mock generator is used)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
